# FastAPI settings
PROJECT_NAME="AI Architecture Code Reviewer"
API_V1_STR="/api/v1"

# GitHub App Configuration
# Replace these with your GitHub App values
GITHUB_APP_ID="your_github_app_id"
GITHUB_CLIENT_ID="your_github_client_id"
GITHUB_CLIENT_SECRET="your_github_client_secret"
GITHUB_WEBHOOK_SECRET="your_optional_webhook_secret"

# GITHUB_PRIVATE_KEY can be either:
# 1. The absolute path to your downloaded .pem file, e.g. "/absolute/path/to/key.pem"
# 2. The relative path from the backend folder, e.g. "key.pem"
# 3. The raw private key string with newline characters escaped as \n, wrapped in double quotes.
GITHUB_PRIVATE_KEY="key.pem"
