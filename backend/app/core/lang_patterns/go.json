    ".Find(", ".First(", ".Save(", ".Create(", ".Delete(", ".Update(", ".Where(",
    "http.Get(", "http.Post(", "http.NewRequest(",
    "client.Get(", "client.Post(", "client.Do(",
    "repository.Find", "repository.Save", "repository.Delete"
  ],
  "blocking_patterns": [
    "time.Sleep(", "sync.Mutex.Lock(", "wg.Wait(", "channel <-", "<-channel",
